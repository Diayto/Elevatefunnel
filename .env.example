# Шаблон переменных окружения
# Скопируйте этот файл в .env и заполните значения:
#   copy .env.example .env   (Windows)
#
# После изменений перезапустите dev-сервер: npm run dev

# === Сайт ===
# Канонический URL для sitemap, Open Graph и canonical
NEXT_PUBLIC_SITE_URL=https://www.elevateintern.com

# === Google Sheets — куда сохраняются анкеты ===
#
# Как получить GOOGLE_SHEETS_WEBHOOK_URL:
# 1. Google Таблица → Расширения → Apps Script
# 2. Код из scripts/google-sheets-webhook.gs
# 3. Развернуть → Новое развертывание → Веб-приложение
# 4. Запуск от имени: Я | Доступ: Все
# 5. Скопировать URL (.../exec) сюда ↓
#
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/ВАШ_SCRIPT_ID/exec

# Тот же секрет, что const WEBHOOK_SECRET в Apps Script
GOOGLE_SHEETS_WEBHOOK_SECRET=

# === Защита API ===
# Лимит запросов с одного IP (in-memory; на Vercel при нескольких инстансах — ослаблен).
# Для рекламного трафика включите Vercel Firewall / Rate Limiting в дашборде проекта.
LEAD_RATE_LIMIT_MAX=15
LEAD_RATE_LIMIT_WINDOW_MINUTES=10
